# Hoox Gateway Worker Environment Variables (local development)
# Copy to .dev.vars and replace with actual values from `hoox setup` output.
# .dev.vars is gitignored — never commit secrets.

# Internal auth key used for service-to-service authentication
INTERNAL_KEY_BINDING=your_internal_key_binding_here

# Webhook API key for external webhook authentication
WEBHOOK_API_KEY_BINDING=your_api_secret_key_here

# Service URLs for local development (wrangler dev will use service bindings
# when running all workers together, but these can be set explicitly if needed)
# TRADE_SERVICE=http://localhost:8788
# TELEGRAM_SERVICE=http://localhost:8790
